{
  "name": "arcp-host-dashboard",
  "private": true,
  "version": "0.1.0",
  "packageManager": "bun@1.2.9",
  "type": "module",
  "scripts": {
    "dev": "vite --port 1420 --strictPort",
    "check": "bunx tsc --noEmit && vite build",
    "build": "vite build",
    "preview": "vite preview --port 1420 --strictPort",
    "tauri": "node ./scripts/tauri-launch.mjs",
    "tauri:dev": "node ./scripts/tauri-launch.mjs dev",
    "tauri:build:bin": "bunx tauri build --no-bundle",
    "tauri:run:bin": "node ./scripts/run-release.mjs",
    "tauri:build:linux:x64": "bunx tauri build --target x86_64-unknown-linux-gnu --bundles deb,rpm",
    "tauri:build:linux:x64:appimage": "bunx tauri build --target x86_64-unknown-linux-gnu --bundles appimage",
    "tauri:build:linux:arm64": "bunx tauri build --target aarch64-unknown-linux-gnu --bundles deb,rpm",
    "tauri:build:linux:arm64:appimage": "bunx tauri build --target aarch64-unknown-linux-gnu --bundles appimage",
    "tauri:build:windows:x64": "bunx tauri build --target x86_64-pc-windows-msvc --bundles msi,nsis",
    "tauri:build:windows:arm64": "bunx tauri build --target aarch64-pc-windows-msvc --bundles msi,nsis",
    "tauri:build:macos:x64": "bunx tauri build --target x86_64-apple-darwin --bundles app,dmg",
    "tauri:build:macos:arm64": "bunx tauri build --target aarch64-apple-darwin --bundles app,dmg",
    "docker:build:linux:x64": "bash ./scripts/docker-build.sh linux-x64",
    "docker:build:linux:x64:appimage": "bash ./scripts/docker-build.sh linux-x64-appimage",
    "docker:build:linux:x64:bin": "bash ./scripts/docker-build.sh linux-x64-bin",
    "docker:build:linux:arm64": "bash ./scripts/docker-build.sh linux-arm64",
    "docker:build:linux:arm64:appimage": "bash ./scripts/docker-build.sh linux-arm64-appimage",
    "docker:build:linux:arm64:bin": "bash ./scripts/docker-build.sh linux-arm64-bin",
    "docker:build:linux:all": "bash ./scripts/docker-build.sh linux-all"
  },
  "dependencies": {
    "@fortawesome/fontawesome-svg-core": "^7.2.0",
    "@fortawesome/free-solid-svg-icons": "^7.2.0",
    "@fortawesome/svelte-fontawesome": "^0.2.4",
    "@tauri-apps/api": "2.10.1",
    "three": "^0.183.1"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "7.0.0",
    "@tauri-apps/cli": "2.10.0",
    "svelte": "5.53.3",
    "typescript": "5.9.3",
    "vite": "7.3.1"
  }
}
